// Identifies the view/page context a conversation is scoped to.
// Sitewide = general chat not tied to any entity.
// Entity-scoped types (Bill, Hearing, etc.) require a view_entity_id pointing to the entity's PK.
enum ConversationViewType {
  Sitewide   @map("sitewide")
  Bill       @map("bill")
  Hearing    @map("hearing")
  Article    @map("article")
  Legislator @map("legislator")
  Report360  @map("report_360")

  @@map("conversation_view_type")
}

/// AI chat conversation. Each conversation is scoped to a view type (e.g. a specific bill page,
/// report page, or sitewide). The UUID primary key doubles as the LangGraph checkpoint thread_id.
model Conversation {
  /// UUID primary key — also the LangGraph checkpoint thread_id for state persistence.
  id             String               @id @default(uuid()) @db.Uuid
  /// The user who owns this conversation. Used for access control.
  user_id        Int
  /// The view/page context this conversation belongs to.
  view_type      ConversationViewType
  /// PK of the entity in the scoped view (e.g. bill_id, hearing_id). Null when view_type is Sitewide.
  view_entity_id Int?
  /// Optional human-readable title for display in conversation lists.
  title          String?              @db.VarChar(255)
  /// Whether the conversation is visible to the user. False = soft-deleted.
  visible        Boolean              @default(true)
  /// When the conversation was first created.
  created_at     DateTime             @default(now()) @db.Timestamptz(6)
  /// When the conversation was last active (updated on each new message).
  updated_at     DateTime             @updatedAt @db.Timestamptz(6)

  user              Profile           @relation(fields: [user_id], references: [user_id])
  checkpoints       Checkpoint[]
  checkpoint_writes CheckpointWrite[]

  @@index([user_id, view_type, view_entity_id])
  @@index([user_id])
  @@map("conversation")
}

/// Stores serialized LangGraph agent state per conversation thread. Each row is a checkpoint
/// representing the full graph state at a point in the conversation.
model Checkpoint {
  /// Conversation UUID (FK to conversation.id). Groups all checkpoints for a thread.
  thread_id            String  @db.Uuid
  /// Namespace for subgraph isolation. Empty string for top-level graphs.
  checkpoint_ns        String  @default("")
  /// Unique identifier for this checkpoint within the thread and namespace.
  checkpoint_id        String
  /// The checkpoint this one was derived from. Null for the first checkpoint.
  parent_checkpoint_id String?
  /// Serialization format identifier (e.g. msgpack, json).
  type                 String?
  /// Serialized graph state including channel versions and pending task info.
  checkpoint           Json
  /// Checkpoint metadata: step count, source (input/loop), timestamp, parent config.
  metadata             Json    @default("{}")

  conversation Conversation @relation(fields: [thread_id], references: [id])

  @@id([thread_id, checkpoint_ns, checkpoint_id])
  @@index([metadata], type: Gin)
  @@map("checkpoint")
}

/// Stores serialized channel data for each checkpoint. Channels hold the actual message history,
/// tool results, and other state values.
model CheckpointBlob {
  /// Auto-incrementing surrogate primary key.
  id            Int    @id @default(autoincrement())
  /// Conversation UUID. Joined to checkpoint via (thread_id, checkpoint_ns).
  thread_id     String @db.Uuid
  /// Namespace for subgraph isolation.
  checkpoint_ns String @default("")
  /// Channel name (e.g. messages, tools, agent).
  channel       String
  /// Channel version string. Incremented when channel data changes.
  version       String
  /// Serialization format identifier.
  type          String
  /// Serialized channel data. Null when channel has been cleared.
  blob          Bytes?

  @@unique([thread_id, checkpoint_ns, channel, version])
  @@map("checkpoint_blob")
}

/// Stores pending writes from in-progress agent tasks. These are writes that have not yet
/// been committed to a checkpoint.
model CheckpointWrite {
  /// Auto-incrementing surrogate primary key.
  id            Int     @id @default(autoincrement())
  /// Conversation UUID (FK to conversation.id).
  thread_id     String  @db.Uuid
  /// Namespace for subgraph isolation.
  checkpoint_ns String  @default("")
  /// The checkpoint these writes are associated with.
  checkpoint_id String
  /// The task that produced this write.
  task_id       String
  /// Write index within the task. Orders multiple writes from the same task.
  idx           Int
  /// Target channel for this write.
  channel       String
  /// Serialization format identifier.
  type          String?
  /// Serialized write data.
  blob          Bytes

  conversation Conversation @relation(fields: [thread_id], references: [id])

  @@unique([thread_id, checkpoint_ns, checkpoint_id, task_id, idx])
  @@map("checkpoint_write")
}
