// This is your Prisma schema file
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DB_URL")
}

/// This should be used in all tables which we start collection first party data. Ex: DirectoryLegislator
enum DataPriority {
  HIGH   @map("1") // State Affairs Manual
  MEDIUM @map("2") // State Affairs Automation
  LOW    @map("3") // Legiscan and others 3rd party (ex. open states)
}

enum Confidence {
  LOW
  MEDIUM
  HIGH
}

enum BillProgressStatus {
  IntroducedCrossoverApproaching           @map("introduced_crossover_approaching")
  IntroducedCrossoverPassed                @map("introduced_crossover_passed")
  IntroducedAdjournmentApproaching         @map("introduced_adjournment_approaching")
  IntroducedAdjournmentPassed              @map("introduced_adjournment_passed")
  Introduced                               @map("introduced")
  PassedFirstChamberAdjournmentApproaching @map("passedfirstchamber_adjournment_approaching")
  PassedFirstChamberAdjournmentPassed      @map("passedfirstchamber_adjournment_passed")
  PassedFirstChamber                       @map("passedfirstchamber")
  PassedSecondChamber                      @map("passedsecondchamber")
  PassedSecondChamberVetoed                @map("passedsecondchamber_vetoed")
  Failed                                   @map("failed")
  Prefiled                                 @map("prefiled")
}

enum BillReferralStatus {
  active
  inactive
}

enum OriginType {
  state_affairs
  legiscan
  ma_docket
  scraper
  gongwer
}

enum LocationType {
  CapitolBuilding
  CommitteeRoom
  HearingRoom
  ExecutiveOffice
  JudicialChamber
  PublicForum
  ConferenceCenter
  Virtual
  Other
}

enum IntroductionType {
  Introduced
  Prefiled
}

enum Represents {
  individual
  organization

  @@map("represents")
}

enum ChargebeeDemoTestType {
  SalesDemo
  EngTest

  @@map("chargebee_demo_test_type")
}

enum HearingType {
  Committee
  Floor
  Other
  PDAB

  @@map("hearing_type")
}

enum ResolutionProgressStatus {
  InProgress
  Passed
  Failed

  @@map("resolution_bill_progress_status")
}

enum InternalNoteAssociatedTable {
  bill       @map("bill")
  bill_event @map("bill_event")
  meeting    @map("meeting")

  @@map("internal_note_associated_table")
}

enum NounType {
  //noun   + corresponding table name
  Hearing    @map("hearing")
  Schedule   @map("schedule")
  Legislator @map("directories_legislators")
  Article    @map("article")
  Bill       @map("bill")
  FieldNote  @map("lobbyist_report")
  Tweet      @map("tweets")

  @@map("noun_type")
}

enum CollectionNounAddedByType {
  User   @map("user")
  Agent  @map("agent")
  System @map("system")

  @@map("collection_noun_added_by_type")
}

/// A join table linking a collection to a polymorphic noun reference.
model CollectionNoun {
  id               Int                       @id @default(autoincrement())
  /// The owning collection identifier.
  collection_id    Int
  /// The noun source table.
  noun_type        NounType
  /// The noun record identifier in the table represented by noun_type.
  noun_id          Int
  /// The user that added this noun to the collection.
  added_by_user_id Int?
  /// The source type for who added this noun.
  added_by_type    CollectionNounAddedByType @default(System)
  /// Optional metadata for additional noun attributes.
  metadata         Json?
  created_at       DateTime                  @default(now())
  collection       Collection                @relation(fields: [collection_id], references: [id], onDelete: Cascade)
  added_by_user    Profile?                  @relation(fields: [added_by_user_id], references: [user_id], onDelete: SetNull)

  @@unique([collection_id, noun_type, noun_id])
  @@index([collection_id])
  @@index([noun_type, noun_id])
  @@map("collection_noun")
}

/// A join table linking a comment to a polymorphic noun reference.
model CommentNounMention {
  id             Int      @id @default(autoincrement())
  /// The referenced comment identifier.
  comment_id     Int
  /// The noun source table.
  noun_type      NounType
  /// The noun record identifier in the table represented by noun_type.
  noun_id        Int
  /// Preview string for the mention, most of the data is static so we can avoid a join here
  preview_string String?

  created_at DateTime @default(now())
  comment    Comment  @relation(fields: [comment_id], references: [id], onDelete: Cascade)

  @@unique([comment_id, noun_type, noun_id])
  @@index([comment_id])
  @@index([noun_type, noun_id])
  @@map("comment_noun_mention")
}

/// A join table linking a comment to a mentioned user.
model CommentUserMention {
  id                Int      @id @default(autoincrement())
  /// The referenced comment identifier.
  comment_id        Int
  /// The mentioned user identifier.
  mentioned_user_id Int
  created_at        DateTime @default(now())
  comment           Comment  @relation(fields: [comment_id], references: [id], onDelete: Cascade)
  mentioned_user    Profile  @relation(fields: [mentioned_user_id], references: [user_id], onDelete: Cascade)

  @@unique([comment_id, mentioned_user_id])
  @@index([comment_id])
  @@index([mentioned_user_id])
  @@map("comment_user_mention")
}

/// A container used to group heterogeneous nouns.
model Collection {
  id Int @id @default(autoincrement())

  report_360_id Int?
  report_360    Report360? @relation("report_360_collections", fields: [report_360_id], references: [id], onDelete: Cascade)

  version Int?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  collection_nouns        CollectionNoun[]
  current_for_report_360  Report360?            @relation("report_360_current_collection")
  report_360_recent_views Report360RecentView[]

  @@unique([report_360_id, version])
  @@index([report_360_id])
  @@map("collection")
}

model Bill {
  /// Auto-incrementing integer ID. Do not use for foreign keys; use uuid instead.
  id                                Int                 @unique @default(autoincrement())
  uuid                              String              @id
  bill_id                           Int?                @unique
  state_id                          Int
  session_id                        Int                 @map("session_id")
  session                           Session             @relation(fields: [session_id], references: [session_id])
  body_id                           Int
  current_body_id                   Int
  bill_type_id                      Int
  bill_number                       String              @db.Citext
  bill_number_normalized            String?
  status_id                         Int
  status_date                       DateTime?           @db.Date
  title                             String              @db.Citext
  description                       String              @db.Citext
  caption                           String?             @db.Citext
  fiscal_note_summary               String?
  is_broad_bill                     Boolean             @default(false)
  amendment_summary                 String?             @db.Citext
  pending_committee_id              Int
  pending_directories_committees_id Int?
  pending_directory_committee       DirectoryCommittee? @relation(fields: [pending_directories_committees_id], references: [id])
  legiscan_url                      String              @db.Citext
  state_url                         String              @db.Citext
  change_hash                       String              @db.Citext
  updated                           DateTime            @updatedAt
  created                           DateTime            @default(now())
  sa_bill_number                    String?             @db.Text
  sa_title                          String?             @db.Citext
  sa_description                    String?             @db.Citext
  metadata                          Json?
  is_active                         Boolean?            @default(true)
  notify_on_legiscan_updates        Boolean             @default(true)
  is_verified                       Boolean             @default(true)
  is_vetoed                         Boolean             @default(false)
  is_failed                         Boolean             @default(false)
  ignore_crossover                  Boolean             @default(false)
  automate_bill_progress            Boolean             @default(true)
  daily_update_date                 DateTime?           @db.Date

  created_at               DateTime @default(now())
  updated_at               DateTime @updatedAt
  notification_action_time DateTime @default(now())

  created_by_user_id      Int?
  updated_by_user_id      Int?
  summary                 String?
  progress_status         BillProgressStatus?
  origin_type             OriginType?
  referrals               BillReferral[]
  history                 BillHistory[]
  history_entries         BillHistoryEntry[]
  progress                BillProgress[]
  sponsors                BillSponsor[]
  votes                   BillVote[]
  texts                   BillText[]
  amendments              BillAmendment[]
  supplements             BillSupplement[]
  bill_events             BillEvent[]
  bill_event_bill_orders  BillEventBillOrder[]
  sasts                   BillSast[]
  subjects                BillSubject[]
  calendar                BillCalendar[]
  trackings               TrackingList[]
  user_bill_notifications UserBillNotifications[]
  state                   State                     @relation(fields: [state_id], references: [state_id])
  signal                  Signal[]
  group_details           GroupDetail[]
  billReasons             BillReason[]
  billTagForms            BillTagForm[]
  comments                BillComment[]
  billCategories          BillCategory[]
  reports                 ReportBills[]
  companions              CompanionBill[]           @relation("companion_source")
  companion_of            CompanionBill[]           @relation("companion_target")
  uploaded_documents      BillUploadedDocument[]
  bill_annotations        BillAnnotation[]
  citation_references     CitationReference[]
  effective_dates         BillEffectiveDate[]
  legislative_progress    BillLegislativeProgress[]
  introduction_dates      BillIntroductionDate[]
  bill_embeddings         BillEmbedding[]
  bill_hearings           BillHearing[]
  whip_counts             BillWhipCount[]
  public_chapter          BillPublicChapter[]
  ignored_bills           IgnoredBills[]
  sys_period              Unsupported("tsrange")    @default(dbgenerated("tsrange(LOCALTIMESTAMP, NULL::timestamp(3) without time zone)"))
  version                 Int                       @default(1)
  last_edited_by          OriginType                @default(legiscan)
  lobbyist_reports        LobbyistReportBill[]
  article_references      ArticleReference[]
  meeting_bills           MeetingBill[]
  bill_sort_class         Int                       @default(dbgenerated()) @db.SmallInt
  bill_sort_num           Int                       @default(dbgenerated())
  bill_sort_suffix        String                    @default(dbgenerated())
  predictions             BillPrediction[]

  resolution_progress_status ResolutionProgressStatus?
  resolution_progress_date   DateTime?                 @db.Date

  // While this is "@ignored" by default, ignore doesn't apply to the schema
  keyword_search_vector      Unsupported("tsvector")? @default(dbgenerated())
  bill_notification_statuses BillNotificationStatus[]

  @@index([keyword_search_vector], type: Gin, map: "idx_bill_fts_search_vector")
  @@index([bill_number_normalized(ops: raw("gin_trgm_ops"))], type: Gin, map: "idx_bills_bill_number_trgm")
  @@index([state_id(sort: Asc), session_id(sort: Asc), bill_number(sort: Asc)])
  @@index([pending_committee_id])
  @@index([pending_directories_committees_id])
  @@index([state_id, session_id])
  @@index([session_id])
  @@index([session_id, uuid])
  @@index([is_active, bill_sort_class, bill_sort_num, bill_sort_suffix, session_id])
  @@index([state_id, daily_update_date])
  @@index([state_id, uuid])
  @@map("bill")
}

model BillLegislativeProgress {
  id              Int        @id @default(autoincrement())
  created_author  BillAuthor @default(STATE_AFFAIRS)
  step_number     Int
  bill_uuid       String
  progress_status String
  progress_date   DateTime?  @db.Date
  label           String?
  committee_id    Int?
  created_at      DateTime   @default(now())
  updated_at      DateTime   @updatedAt

  bill      Bill                @relation(fields: [bill_uuid], references: [uuid])
  committee DirectoryCommittee? @relation(fields: [committee_id], references: [id])

  @@unique([step_number, bill_uuid, created_author])
  @@index([bill_uuid])
  @@index([bill_uuid, created_author, step_number])
  @@map("bill_legislative_progress")
}

// prediction = ML model output, outcome = actual legislative result
enum PredictionType {
  prediction
  outcome

  @@map("prediction_type")
}

model BillPrediction {
  id            Int      @id @default(autoincrement())
  bill_uuid     String
  score         Float
  snapshot_step Int
  model_version String
  scored_at     DateTime @default(now())

  ///  SHAP explanation fields for "Why this score?"
  shap_values Json? // Top N feature contributions
  /// SHAP base value (model's average prediction)
  base_value  Float?

  prediction_type PredictionType? @default(prediction)
  /// Timestamp of the legislative action this snapshot represents
  snapshot_date   DateTime?

  bill Bill @relation(fields: [bill_uuid], references: [uuid])

  @@unique([bill_uuid, snapshot_step, model_version])
  @@index([bill_uuid, scored_at])
  @@map("bill_prediction")
}

model BillLegislativeProgressVariant {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  name        String
  total_steps Int
  steps_json  Json
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  states      State[]

  @@map("bill_legislative_progress_variant")
}

model CompanionBill {
  bill_id_1          Int?
  bill1              Bill     @relation("companion_source", fields: [bill_uuid_1], references: [uuid])
  bill_id_2          Int?
  bill2              Bill     @relation("companion_target", fields: [bill_uuid_2], references: [uuid])
  bill_uuid_1        String
  bill_uuid_2        String
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt
  created_by_user_id Int?
  updated_by_user_id Int?

  @@id([bill_uuid_1, bill_uuid_2])
  @@index([bill_uuid_1])
  @@index([bill_uuid_2])
  @@map("companion_bill")
}

model Session {
  session_id                     Int       @id @map("session_id")
  state_id                       Int
  year_start                     Int
  year_end                       Int
  prefile                        Int?      @default(0)
  sine_die                       Int?      @default(0)
  prior                          Int?      @default(0)
  special                        Int
  session_name                   String    @db.Citext
  session_title                  String    @db.Citext
  session_tag                    String    @db.Citext
  import_date                    DateTime? @db.Date
  recess_start                   DateTime? @db.Date
  recess_end                     DateTime? @db.Date
  second_year_crossover_deadline DateTime? @db.Date

  import_hash        String?  @db.Citext
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt
  created_by_user_id Int?
  updated_by_user_id Int?

  // Legislative Session
  session_start_date       DateTime? @db.Date
  session_adjournment_date DateTime? @db.Date
  house_intro_deadline     DateTime? @db.Date
  senate_intro_deadline    DateTime? @db.Date
  cross_over_deadline      DateTime? @db.Date
  carry_over_status        Json?
  legislative_notes        String?   @db.Citext

  bills        Bill[]
  configs      StateConfig[]
  plan_configs PlanConfig[]
  Reports      Reports[]
  state        State?        @relation(fields: [state_id], references: [state_id])
  hearings     Hearing[]

  @@index([state_id, year_start])
  @@index([state_id, year_end])
  @@index([state_id, session_start_date])
  @@index([state_id, session_id])
  @@index([year_start])
  @@index([year_end])
  @@index([session_start_date])
  @@map("session")
}

model Committee {
  committee_id                           Int      @id @map("committee_id")
  committee_body_id                      Int
  committee_name                         String?  @default("") @db.Citext
  created_at                             DateTime @default(now())
  updated_at                             DateTime @updatedAt
  created_by_user_id                     Int?
  updated_by_user_id                     Int?
  directories_committees_id              Int?
  awaiting_review_directory_committee_id Int?

  body                      Body?               @relation(fields: [committee_body_id], references: [body_id])
  directory_committee       DirectoryCommittee? @relation(fields: [directories_committees_id], references: [id])
  awaiting_review_committee DirectoryCommittee? @relation("AwaitingReviewCommittee", fields: [awaiting_review_directory_committee_id], references: [id])

  @@index([committee_body_id(sort: Asc)])
  @@map("committee")
}

model CommitteeAlias {
  id           Int      @id @default(autoincrement())
  committee_id Int
  name         String
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  /// Generated column for fuzzy name search (managed by database, read-only)
  name_norm String? @default(dbgenerated())

  committee DirectoryCommittee @relation(fields: [committee_id], references: [id])

  @@index([committee_id])
  @@index([name_norm(ops: raw("gist_trgm_ops"))], type: Gist, map: "committee_alias_name_trgm_gist")
  @@map("committee_alias")
}

model BillReferral {
  bill_referral_id          Int                 @id @default(autoincrement())
  bill_id                   Int?
  bill_uuid                 String
  referral_step             Int?
  referral_date             DateTime?           @db.Date
  committee_id              Int?
  directories_committees_id Int?
  status                    BillReferralStatus?
  created_at                DateTime            @default(now())
  updated_at                DateTime            @updatedAt
  created_by_user_id        Int?
  updated_by_user_id        Int?
  bill                      Bill                @relation(fields: [bill_uuid], references: [uuid])
  directory_committee       DirectoryCommittee? @relation("BillReferralDirectoryCommittee", fields: [directories_committees_id], references: [id])

  // Note: DB constraint ensures at least one of committee_id or directories_committees_id is NOT NULL (@@check not allowed in prisma)
  @@unique([bill_uuid, referral_step])
  @@unique([bill_id, referral_step])
  @@map("bill_referral")
}

model BillReason {
  id                 Int       @id @default(autoincrement())
  bill_id            Int?
  bill_uuid          String
  reason_id          Int
  created            DateTime? @default(now())
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt
  created_by_user_id Int?
  updated_by_user_id Int?

  bill   Bill   @relation(fields: [bill_uuid], references: [uuid])
  reason Reason @relation(fields: [reason_id], references: [reason_id])

  @@index([bill_id(sort: Asc)])
  @@map("bill_reason")
}

model BillProgress {
  id                 Int       @id @default(autoincrement())
  bill_id            Int?      @map("bill_id")
  bill_uuid          String
  progress_step      Int
  progress_date      DateTime? @db.Date
  progress_event_id  Int
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt
  created_by_user_id Int?
  updated_by_user_id Int?
  bill               Bill      @relation(fields: [bill_uuid], references: [uuid])
  progress_event     Progress  @relation(fields: [progress_event_id], references: [progress_event_id])

  @@unique([bill_uuid, progress_step])
  @@unique([bill_id, progress_step])
  @@map("bill_progress")
}

model BillPublicChapter {
  id                    Int      @id @default(autoincrement())
  bill_uuid             String
  public_chapter_number Int
  public_chapter_pdf    String
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  bill Bill @relation(fields: [bill_uuid], references: [uuid])

  @@map("bill_public_chapter")
}

model IgnoredBills {
  id         Int      @id @default(autoincrement())
  bill_uuid  String
  type       String
  reason     String?
  ignored_by Int?
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  bill Bill @relation(fields: [bill_uuid], references: [uuid])

  @@unique([bill_uuid, type])
  @@map("ignored_bills")
}

enum BillHistoryAuthor {
  STATE_AFFAIRS
  LEGISCAN
  SCRAPER
}

enum BillHistoryEventSource {
  STATE_AFFAIRS
  LEGISCAN
  SCRAPER

  @@map("bill_history_event_source")
}

model BillHistory {
  bill_id                   Int?      @map("bill_id")
  bill_uuid                 String
  history_step              Float
  history_major             Int
  history_body_id           Int
  history_date              DateTime? @db.Date
  history_action            String    @db.Citext
  autolinked_history_action String?   @db.Citext
  sa_linked_history_action  String?
  sa_history_action         String?   @db.Citext
  is_sa_history_action_live Boolean   @default(false)
  created_at                DateTime  @default(now())
  updated_at                DateTime  @updatedAt
  created_by_user_id        Int?
  updated_by_user_id        Int?

  created_author BillHistoryAuthor? @default(LEGISCAN)
  hide           Boolean            @default(false)

  bill Bill @relation(fields: [bill_uuid], references: [uuid])

  @@id([bill_uuid, history_step])
  @@unique([bill_id, history_step])
  @@index([bill_uuid, hide, history_step], map: "bill_history_uuid_hide_step_idx")
  @@index([bill_uuid, history_major, history_step], map: "bill_history_uuid_major_step_idx")
  @@index([bill_uuid, hide, history_date, created_at], map: "bill_history_uuid_hide_date_created_idx")
  @@index([bill_uuid, history_date])
  @@index([history_date, hide, bill_uuid], map: "bill_history_date_hide_uuid_idx")
  @@index([bill_uuid, hide], map: "bill_history_uuid_hide_idx")
  @@map("bill_history")
}

/// A relation between a BillHistoryEvent (text, creation info, etc) and a specific bill
model BillHistoryEntry {
  id                    Int      @id @default(autoincrement())
  /// The bill in the relation
  bill_uuid             String
  /// The event information in the relation
  bill_history_event_id Int
  bill_id               Int?     @map("bill_id")
  /// History step info (this is unique per bill)
  history_step          Float
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  bill               Bill             @relation(fields: [bill_uuid], references: [uuid])
  bill_history_event BillHistoryEvent @relation(fields: [bill_history_event_id], references: [id])

  @@unique([bill_uuid, bill_history_event_id])
  @@unique([bill_uuid, history_step])
  @@index([bill_history_event_id])
  @@map("bill_history_entry")
}

/// Bill History Event information (text, creation info, date, etc).
/// Can be associated with 1+ bills via the BillHistoryEntry table.
/// Typically associated with more than 1 bill in the case of a companion bill.
model BillHistoryEvent {
  id                        Int                     @id @default(autoincrement())
  /// Sourced from Legiscan, whether an event is considered more important and potentially worth notifying on
  history_major             Int
  history_body_id           Int
  history_date              DateTime?               @db.Date
  /// History action text from Legiscan/first party, or SA text if a manually entered event
  history_action            String                  @db.Text
  /// History action will markdown links to the bills mentioned in the history
  autolinked_history_action String?                 @db.Text
  /// Admin override of autolink_history_action
  sa_linked_history_action  String?
  /// Override of Legiscan/first party text, or SA text if a manually entered event
  sa_history_action         String?                 @db.Text
  is_sa_history_action_live Boolean                 @default(false)
  created_at                DateTime                @default(now())
  updated_at                DateTime                @updatedAt
  created_by_user_id        Int?
  updated_by_user_id        Int?
  /// The source of the History Event
  created_source            BillHistoryEventSource? @default(LEGISCAN)
  hide                      Boolean                 @default(false)

  bill_history_entries BillHistoryEntry[]

  @@index([hide, history_date, created_at], map: "bill_history_event_hide_date_created_idx")
  @@index([history_date, hide], map: "bill_history_event_date_hide_idx")
  @@index([hide], map: "bill_history_event_hide_idx")
  @@index([history_major], map: "bill_history_event_major_idx")
  @@map("bill_history_event")
}

model BillHistoryAction {
  id           Int     @id @default(autoincrement())
  abbreviation String?
  name         String
  state_id     Int
  type         String
  progress_id  Int?

  generic_action_type    Int?
  generic_committee_type String?
  next_committee         String?
  next_committee_id      Int?
  next_subcommittee      String?
  next_subcommittee_id   Int?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  state      State    @relation(fields: [state_id], references: [state_id])

  @@map("bill_history_action")
}

model BillEffectiveDate {
  id             Int      @id @default(autoincrement())
  bill_uuid      String
  effective_date DateTime @db.Date
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  section        String?

  bill Bill @relation(fields: [bill_uuid], references: [uuid])

  @@index([bill_uuid])
  @@map("bill_effective_date")
}

model BillIntroductionDate {
  id                Int              @id @default(autoincrement())
  bill_uuid         String
  body_id           Int
  introduction_date DateTime         @db.Date
  introduction_type IntroductionType @default(Introduced)
  created_at        DateTime         @default(now())
  updated_at        DateTime         @updatedAt

  body Body @relation(fields: [body_id], references: [body_id])
  bill Bill @relation(fields: [bill_uuid], references: [uuid])

  @@index([bill_uuid])
  @@map("bill_introduction_date")
}

model BillSponsor {
  bill_id            Int?
  bill_uuid          String
  people_id          Int
  sponsor_order      Int
  sponsor_type_id    Int
  manually_added     Boolean   @default(false)
  updated            DateTime? @default(now())
  created            DateTime? @default(now())
