  updated_at DateTime                    @updatedAt
  hearing    Hearing                     @relation(fields: [entity_id], references: [entity_id])

  @@unique([entity_id, chunk_id])
  @@index([entity_id])
  @@index([embedding], map: "hearing_embedding_embedding_idx")
  @@map("hearing_embedding")
}

