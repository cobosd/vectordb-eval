/// Links Twitter/X accounts to legislators. Used by the Twitter bot cron to ingest timeline tweets,
/// by the follow/unfollow crons to manage which accounts the bot tracks.
/// Also managed by admin when changing a legislator's Twitter handle during add/edit flows.
model DirectoryLegislatorTwitter {
  /// Twitter user ID returned by the v2 API (e.g. "1833208038154473473"). Primary key.
  twitter_id         String   @id @db.Citext
  /// Display name from the Twitter API
  name               String   @db.Citext
  /// Twitter @handle (without the @). Looked up via TwitterApi.v2.userByUsername in linkTwitterAccountsToLegislator.
  username           String   @db.Citext
  /// FK to DirectoryLegislator. Set when linking an account to a legislator; null for unlinked accounts.
  legislator_id      Int?
  /// Whether the SA bot is currently following this account on Twitter. Toggled by the follow/unfollow crons.
  bot_following      Boolean  @default(false)
  /// Whether the SA bot should follow this account. Admin-controlled via updateBotFollowTwitterAccount mutation.
  bot_should_follow  Boolean  @default(true)
  /// Legislator's state, denormalized from DirectoryLegislator.address_state_id for cron tweet ingestion filtering.
  state_id           Int?
  // Legacy timestamp pair — prefer created_at/updated_at
  createdAt          DateTime @default(now())
  updatedAt          DateTime @default(now()) @updatedAt
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt
  created_by_user_id Int?
  updated_by_user_id Int?

  state      State?               @relation(fields: [state_id], references: [state_id])
  legislator DirectoryLegislator? @relation(fields: [legislator_id], references: [id])

  @@map("directories_twitter_accounts")
}

