model Article {
  id                Int      @id @default(autoincrement())
  wp_id             Int?
  slug              String
  /// this is the unique identifier for incoming updates
  post_name         String
  post_title        String?
  post_date         DateTime
  post_content      String?
  /// post_content stripped of WP and html
  post_content_text String?
  excerpt           String?
  /// one of ACCESS_OPTIONS
  access            String?
  /// .article_states -> state_ids
  state_ids         Int[]    @default([])
  /// .article_tags
  tags              String[] @default([])
  /// .article_sections
  sections          String[] @default([])
  /// .article_types
  types             String[] @default([])
  /// .meta_data.article_ranking
  ranking           Float    @default(0)
  /// [NewsDocument]
  raw_data          Json?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  // While this is "@ignored" by default, ignore doesn't apply to the schema
  keyword_search_vector Unsupported("tsvector")? @default(dbgenerated())

  article_embeddings            ArticleEmbedding[]
  article_embedding_experiments ArticleEmbeddingExperiment[]
  article_references            ArticleReference[]

  // basic lookups
  @@unique([wp_id])
  @@unique([slug])
  @@unique([post_name])
  // Array searches - use GIN indexes
  @@index([state_ids], type: Gin)
  @@index([tags], type: Gin)
  @@index([sections], type: Gin)
  @@index([types], type: Gin)
  // Individual filter columns
  @@index([access])
  @@index([created_at])
  @@index([updated_at])
  @@index([post_date])
  // Sorting columns - composite for search ORDER BY
  @@index([post_date(sort: Desc), ranking(sort: Asc)])
  // JSONB path queries on raw_data
  @@index([raw_data], type: Gin)
  // manual indexes (not supported by prisma)
  // HACK: prisma doesn't support this index, but this is close enough to suppress the migration drift
  @@index([keyword_search_vector], type: Gin, map: "idx_article_search_vector")
  // CREATE INDEX idx_article_search_vector ON article USING GIN(keyword_search_vector);
  // CREATE INDEX idx_article_raw_data_author ON article ((raw_data->>'author_slug'));
  @@map("article")
}

