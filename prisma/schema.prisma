/// Stores user prompts for 360 reports along with their embeddings and LLM-extracted query plans used for retrieval across bills, hearings, and articles modules.
model Report360Prompt {
  report_360_prompt_id Int @id @default(autoincrement())

  report_360_id Int
  report_360    Report360 @relation(fields: [report_360_id], references: [id], onDelete: Cascade)

  /// Raw user prompt text as entered by the user
  prompt          String
  /// 1536-dim OpenAI embedding of the enriched prompt (raw prompt + team context + keywords). Used by the legacy retrieval path for all modules.
  vector          Unsupported("vector(1536)")
  created_at      DateTime                    @default(now())
  updated_at      DateTime
  /// Prompt enriched with team context and keywords, used to generate the legacy vector embedding
  enriched_prompt String                      @default("")

  /// LLM-extracted structured query plan (JSONB). Contains shared filters (semantic_search_text, state_ids, time_window) and bills-specific filters (stage, committee, session, effective_date). Produced by the extraction pipeline; consumed by the v2 retrieval orchestrator.
  query_plan              Json?
  /// LLM-reported confidence score (0..1) for the extracted query plan
  query_plan_confidence   Float?
  /// Extraction pipeline status: PENDING, SUCCESS, LOW_CONFIDENCE, FAILED, or TIMEOUT
  query_plan_status       String?
  /// Error message if extraction failed or timed out
  query_plan_error        String?
  /// Model ID used for the extraction LLM call (e.g. openai_mini)
  query_plan_model        String?
  /// Timestamp of when the query plan was extracted
  query_plan_extracted_at DateTime?
  /// LLM-rewritten topical search text derived from raw user intent (no team context or keywords). Source text for semantic_search_vector.
  semantic_search_text    String?
  /// 1536-dim OpenAI embedding of semantic_search_text. Used by the v2 retrieval path for semantic search across bills, hearings, and articles.
  semantic_search_vector  Unsupported("vector(1536)")?

  /// Synthesized text capturing the semantic intersection of the team prompt (prompt_long) and the user query. Source text for team_prompt_aligned_vector.
  team_prompt_aligned_text   String?
  /// 1536-dim OpenAI embedding of team_prompt_aligned_text. Used to surface items semantically aligned with both the team mission and the specific query.
  team_prompt_aligned_vector Unsupported("vector(1536)")?
  /// Timestamp of when the team-prompt-aligned vector was computed
  team_prompt_aligned_at     DateTime?

  @@map("report_360_prompt")
}

